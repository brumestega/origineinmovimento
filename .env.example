# ============================================================
# Origine in Movimento — variabili d'ambiente
# Copia questo file in `.env.local` e compila i valori reali.
# In produzione (Vercel) inseriscile come Environment Variables.
# ============================================================

# --- Email titolare (usata da prenotazioni e form contatti) ---
OWNER_EMAIL=origineinmovimento@gmail.com

# --- Google Calendar (prenotazioni) ---
# Autenticazione OAuth2 con il refresh token dell'account di Silvia.
# Necessario perché l'account è un Gmail personale: così l'app crea l'evento
# "come Silvia" e Google invia inviti + promemoria email a lei e al cliente.
#
# Come ottenerli:
# 1. Google Cloud Console → crea un progetto → abilita "Google Calendar API".
# 2. Credenziali → OAuth client ID → tipo "Web application".
#    Aggiungi https://developers.google.com/oauthplayground tra i redirect URI.
# 3. OAuth Playground (developers.google.com/oauthplayground):
#    - ingranaggio in alto a destra → "Use your own OAuth credentials" → incolla ID e Secret
#    - scope: https://www.googleapis.com/auth/calendar.events
#    - autorizza con l'account origineinmovimento@gmail.com → "Exchange authorization code for tokens"
#    - copia il "Refresh token".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Calendario su cui creare gli eventi ('primary' = calendario principale dell'account)
GOOGLE_CALENDAR_ID=primary

# --- Email transazionale (form contatti + lead calcolatori) via Resend ---
# https://resend.com → API Keys. Per usare un mittente col dominio del sito,
# verifica il dominio su Resend e imposta CONTACT_FROM_EMAIL di conseguenza.
RESEND_API_KEY=
# Destinatario dei messaggi del form (default: OWNER_EMAIL)
CONTACT_TO_EMAIL=origineinmovimento@gmail.com
# Mittente verificato su Resend (default di test: onboarding@resend.dev)
CONTACT_FROM_EMAIL=Origine in Movimento <onboarding@resend.dev>
